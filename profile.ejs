<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PostAssociation</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
        <a class="bg-red-500 rounded-md px-2 py-2 text-white mb-7 inline-block" href="/logout">Logout</a>
        </div>
        <h3 class="text-4xl mb-10"><span class="font-light">Hello</span> <%= user.name%>,</h3>
        <h5 class="mb-5">You can create a new post</h5>
        <form action = "/post" method="post">
            <textarea placeholder ="What's on your mind ?" class="w-1/3 resize-none bg-transparent border-1 border-zinc-800 rounded-md p-4 outline-none" name="content" ></textarea>
            <input class="px-2 py-2 w-40 bg-blue-500 rounded-md border-white-600 block mt-2" type="Submit" value="Create New Post">
        </form>
        <div class="posts mt-10">
            <h3 class="mb-5">Your Posts</h3>
            <div class="postcontainer">
                <% user.posts.reverse().forEach(function(post){%>
                    <div class="post w-1/3 p-4 border-4 mb-2 border-zinc-700 rounded-md bg-zinc-800 mr-3 inline-block">
                    <h4 class="text-blue-500 mb-1">@<%= user.username %></h4>
                    <p class="text-sm tracking-tighter text-gray-400 mb-2"><%= post.content %></p>
                    <small class="mb-0 inline-block"><%= post.likes.length %> like</small>
                    <div class="btns flex gap-3">
                        <a class="text-blue-500" href="/like/<%= post._id %>">
                            <%= post.likes.indexOf(user._id)===-1 ? "Like" : "Unlike" %>
                        </a>
                        <a class="text-zinc-600" href="/edit/<%= post._id %>">edit</a>
                    </div>
                </div>
                <%})%>                
            </div>
        </div>
    </div>
    
</body>
</html>