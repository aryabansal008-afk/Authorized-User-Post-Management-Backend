<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PostAssociation</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
        <a class="bg-red-500 rounded-md px-2 py-2 text-white mb-7 inline-block" href="/logout">Logout</a>
        </div>
        <h5 class="mb-5">Edit your post</h5>
        <form action = "/update/<%= post._id %>" method="post">
            <textarea placeholder ="What's on your mind ?" class="w-1/3 resize-none bg-transparent border-1 border-zinc-800 rounded-md p-4 outline-none" name="content" ><%= 
                post.content %></textarea>
            <input class="px-2 py-2 w-40 bg-yellow-500 rounded-md border-white-600 block mt-2" type="Submit" value="Update Post">
        </form>
    </div>
    
</body>
</html>