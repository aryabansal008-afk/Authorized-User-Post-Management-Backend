<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PostAssociation</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-4xl mb-4">Create Account</h3>
        <form action ="/register" method="post">
            <input class="px-3 py-4 outline-none bg-transparent border-1 rounded-md border-zinc-800" type = "text" placeholder="username" name="username">
            <input class="px-3 py-4 outline-none bg-transparent border-1 rounded-md border-zinc-800" type = "text" placeholder="name" name="name">
            <input class="px-3 py-4 outline-none bg-transparent border-1 rounded-md border-zinc-800" type = "password" placeholder="password" name = "password">
            <input class="px-3 py-4 outline-none bg-transparent border-1 rounded-md border-zinc-800" type = "email" placeholder="email" name="email">
            <input class="px-3 py-4 outline-none bg-transparent border-1 rounded-md border-zinc-800" type = "number" placeholder="age" name="age">
            <input class="px-3 py-2 outline-none bg-blue-500 border-1 rounded-md border-white-800" type = "submit" value = "Create Account">
        </form>
    </div>
    
</body>
</html>